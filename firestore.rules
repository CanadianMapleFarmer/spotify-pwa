rules_version = '2';

// Pair-session security model:
// - The pair code is a 6-char shared secret displayed simultaneously on the
//   TV and the phone scanning the QR. A document at pairSessions/{pairCode}
//   exists only briefly (the TV deletes after consumption).
// - Writes are anonymous (no auth — this is a TV pairing flow) but only the
//   pairSessions collection is reachable; everything else is denied.
// - TODO(hardening): tighten allow create with field validation + TTL bound
//   once the round-trip is confirmed working from the Firebase JS SDK.

service cloud.firestore {
  match /databases/{database}/documents {
    match /pairSessions/{pairCode} {
      allow read, write: if true;
    }
    // Scene library metadata is written by the Cloud Function (admin SDK,
    // bypasses these rules) and read directly by the client to list available
    // pre-converted JPG-sequence clips. Public read, no client writes.
    match /sceneClips/{clipId} {
      allow read: if true;
      allow write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
